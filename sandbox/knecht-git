#!/usr/bin/env bash
# The bridge CLI inside a Knecht sandbox, for the two things plain git cannot
# do on its own (the run's checkout is a self-contained clone, so everything
# else is just git):
#   - `credential` is the git credential helper wired into the clone's config
#     (server/daemon/git.ts): it fetches a short-lived repo-scoped token from
#     the Knecht host so plain git can push and fetch.
#   - `open-pr` pushes the current branch and opens a pull request host-side
#     (a GitHub API call the sandbox has no other path to).
# See server/routes/agent-bridge.post.ts and sandbox/opencode/AGENTS.md.
set -euo pipefail

usage() {
  cat <<'EOF'
usage:
  knecht-git open-pr -t <title> [-b <body>]  push the current branch and open a pull request
  knecht-git credential <get|store|erase>    git credential helper (wired into the clone's git config)
EOF
  exit 2
}

[ -n "${KNECHT_BRIDGE_URL:-}" ] && [ -n "${KNECHT_BRIDGE_TOKEN:-}" ] && [ -n "${KNECHT_RUN_ID:-}" ] || {
  echo "knecht-git is not available in this run (bridge not configured)" >&2
  exit 1
}

# JSON-encode a string (node is in the image for the js workflow step, so it
# doubles as the JSON encoder here).
json_escape() {
  node -e 'console.log(JSON.stringify(process.argv[1] ?? ""))' "$1"
}

bridge_post() {
  curl -sS -o "$response" -w '%{http_code}' \
    -X POST "$KNECHT_BRIDGE_URL" \
    -H 'content-type: application/json' \
    -H "x-knecht-run-id: $KNECHT_RUN_ID" \
    -H "x-knecht-token: $KNECHT_BRIDGE_TOKEN" \
    --data "$1"
}

op="${1:-}"
shift || true
response="$(mktemp)"
trap 'rm -f "$response"' EXIT

case "$op" in
  credential)
    # git credential helper protocol: git pipes a key=value description on
    # stdin and, for `get`, expects username/password lines back. `store` and
    # `erase` are no-ops (tokens are short-lived, nothing to remember).
    action="${1:-}"
    desc="$(cat)"
    [ "$action" = "get" ] || exit 0
    case "$desc" in
      *host=github.com*) ;;
      *) exit 0 ;;
    esac
    code="$(bridge_post '{"op":"credential"}')"
    case "$code" in
      2*)
        printf 'username=x-access-token\npassword=%s\n' "$(cat "$response")"
        exit 0
        ;;
      *)
        cat "$response" >&2
        exit 1
        ;;
    esac
    ;;
  open-pr)
    title="" body=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        -t) title="${2:-}"; shift 2 ;;
        -b) body="${2:-}"; shift 2 ;;
        *) usage ;;
      esac
    done
    [ -n "$title" ] || usage
    code="$(bridge_post "{\"op\":\"open-pr\",\"title\":$(json_escape "$title"),\"body\":$(json_escape "$body")}")"
    cat "$response"
    case "$code" in
      2*) exit 0 ;;
      *) exit 1 ;;
    esac
    ;;
  *)
    usage
    ;;
esac
