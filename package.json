{
  "name": "knecht-cloud",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "nuxt typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "rm -f \"${KNECHT_DB_PATH:-.data/knecht.db}\"* && drizzle-kit migrate",
    "db:reset:vm": "limactl shell knecht-dev -- bash -lc 'npm run db:reset'",
    "db:studio": "drizzle-kit studio",
    "dev:vm": "limactl shell knecht-dev -- bash scripts/vm-dev.sh",
    "preview:docker": "docker compose up -d --build"
  },
  "dependencies": {
    "@comark/nuxt": "^0.5.0",
    "@nuxt/ui": "^4.8.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.6.0",
    "better-sqlite3": "^12.10.0",
    "dockerode": "^5.0.1",
    "drizzle-orm": "^0.45.2",
    "execa": "^9.6.1",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "^0.5.29",
    "octokit": "^5.0.5",
    "prism-code-editor": "^5.2.0",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.116",
    "@nuxt/eslint": "^1.16.0",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^4.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
