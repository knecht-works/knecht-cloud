# Knecht's TLS entry point (the `caddy` service in docker-compose.yml,
# production only). Two jobs:
#
#   1. Serve the dashboard at https://<KNECHT_BASE_DOMAIN> with a normally
#      managed certificate.
#   2. Serve the per-run preview hosts ([<label>--]<runId>.preview.<base>)
#      with on-demand certificates: those hostnames only exist once a run
#      does, so each one gets its certificate on first request. Knecht's
#      /tls-ask endpoint (server/routes/tls-ask.get.ts) decides which
#      hostnames qualify; that guard is what keeps strangers from draining
#      the Let's Encrypt quota through the wildcard DNS record.
#
# Certificates and the ACME account persist in the caddy-data volume.

{
	on_demand_tls {
		ask http://knecht:3000/tls-ask
	}
}

{$KNECHT_BASE_DOMAIN} {
	reverse_proxy knecht:3000
}

https:// {
	tls {
		on_demand
	}
	reverse_proxy knecht:3000
}
