# Values below are the canonical Linux-server defaults; override them locally.
# Knecht needs a Linux host with Sysbox (local dev: the Lima VM — see
# internals/docs/run-isolation.md §9 and scripts/provision-host.sh).

# DOCKER_GID — group id of the host Docker socket as seen INSIDE a container.
#   Find it:  stat -c '%g' /var/run/docker.sock   (Linux host)
#   A typical Linux host's `docker` group is 999.
DOCKER_GID=999

# KNECHT_PROJECTS — the fixed project path, mounted identically inside and out
# when Knecht runs as a container (the HOST daemon resolves the sandbox
# worktree bind mounts). Same value on BOTH sides.
#   Linux server: /data/knecht/projects
KNECHT_PROJECTS=/data/knecht/projects

# KNECHT_SANDBOX_IMAGE — the per-run sandbox image (sandbox/Dockerfile), built
# on the host by the provisioning script. Default: knecht-sandbox
#KNECHT_SANDBOX_IMAGE=knecht-sandbox

KNECHT_BASE_DOMAIN=lvh.me

# ─── Auth (nuxt-auth-utils) ───────────────────────────────────────────────────
# NUXT_SESSION_PASSWORD — seals the session cookie. Any random string ≥ 32 chars.
#   Generate:  openssl rand -base64 32
NUXT_SESSION_PASSWORD=change-me-to-a-random-string-at-least-32-chars

# GitHub OAuth App (Settings → Developer settings → OAuth Apps → New OAuth App).
#   Authorization callback URL must be:  http://lvh.me:3333/auth/github (dev)
#   (on a server: https://your-host/auth/github)
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=

# ─── Dev login (server/routes/_test/login.get.ts) ─────────────────────────────
# DEV ONLY. Lets an automated agent seed a real session via /_test/login without
# the interactive OAuth flow. The endpoint is stripped from production builds; it
# also stays inert unless BOTH vars below are set. Leave BOTH unset normally.
#   KNECHT_TEST_AUTH        — shared secret; the request must pass ?secret=<this>.
#   KNECHT_TEST_GITHUB_TOKEN — a real GitHub token (classic PAT with `repo` scope,
#                              or an OAuth token) seeded into the session so real
#                              clone/PR operations can be verified. Stays local.
#   Generate a secret:  openssl rand -hex 16
KNECHT_TEST_AUTH=
KNECHT_TEST_GITHUB_TOKEN=
